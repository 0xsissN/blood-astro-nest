---
import DashboardLayout from "../../layouts/dashboard-layout.astro";
---

<DashboardLayout title="Dashboard" activeSection="dashboard">
  <div class="dashboard-page">

    <div class="stock-header">
      <div>
        <h1 class="page-title">Estado del Stock Regional</h1>
        <p class="page-subtitle">Monitoreo en tiempo real de unidades disponibles por grupo sanguíneo.</p>
      </div>
      <span class="updated-badge">Actualizado hace 2 min</span>
    </div>

    <div class="blood-stock-grid">
      <div class="blood-card blood-card--saludable">
        <span class="blood-label">A+</span>
        <span class="blood-count">42</span>
        <span class="blood-status blood-status--saludable">Saludable</span>
      </div>
      <div class="blood-card blood-card--critico">
        <span class="blood-label">A-</span>
        <span class="blood-count blood-count--critico">3</span>
        <span class="blood-status blood-status--critico">CRÍTICO</span>
      </div>
      <div class="blood-card blood-card--saludable">
        <span class="blood-label">B+</span>
        <span class="blood-count">28</span>
        <span class="blood-status blood-status--saludable">Saludable</span>
      </div>
      <div class="blood-card blood-card--bajo">
        <span class="blood-label">B-</span>
        <span class="blood-count">8</span>
        <span class="blood-status blood-status--bajo">Bajo</span>
      </div>
      <div class="blood-card blood-card--saludable">
        <span class="blood-label">O+</span>
        <span class="blood-count">56</span>
        <span class="blood-status blood-status--saludable">Saludable</span>
      </div>
      <div class="blood-card blood-card--critico">
        <span class="blood-label">O-</span>
        <span class="blood-count blood-count--critico">2</span>
        <span class="blood-status blood-status--critico">CRÍTICO</span>
      </div>
      <div class="blood-card blood-card--saludable">
        <span class="blood-label">AB+</span>
        <span class="blood-count">15</span>
        <span class="blood-status blood-status--saludable">Saludable</span>
      </div>
      <div class="blood-card blood-card--bajo">
        <span class="blood-label">AB-</span>
        <span class="blood-count">6</span>
        <span class="blood-status blood-status--bajo">Bajo</span>
      </div>
    </div>

    <div class="middle-section">
      <div class="chart-panel">
        <div class="panel-header">
          <div>
            <h2 class="panel-title">Donaciones Mensuales</h2>
            <p class="panel-subtitle">Histórico de unidades colectadas (Últimos 12 meses)</p>
          </div>
          <select class="year-select">
            <option>Año 2023-2024</option>
            <option>Año 2022-2023</option>
          </select>
        </div>
        <div class="chart-placeholder">
          <div class="chart-bars">
            <div class="bar" style="height:40%"></div>
            <div class="bar" style="height:55%"></div>
            <div class="bar" style="height:35%"></div>
            <div class="bar" style="height:65%"></div>
            <div class="bar" style="height:50%"></div>
            <div class="bar" style="height:70%"></div>
            <div class="bar" style="height:60%"></div>
            <div class="bar" style="height:45%"></div>
            <div class="bar" style="height:55%"></div>
            <div class="bar" style="height:75%"></div>
            <div class="bar" style="height:80%"></div>
            <div class="bar" style="height:65%"></div>
          </div>
          <div class="chart-labels">
            <span>ENE</span><span>FEB</span><span>MAR</span><span>ABR</span>
            <span>MAY</span><span>JUN</span><span>JUL</span><span>AGO</span>
            <span>SEP</span><span>OCT</span><span>NOV</span><span>DIC</span>
          </div>
        </div>
      </div>

      <div class="campaigns-panel">
        <h2 class="panel-title">Campañas Exitosas</h2>
        <div class="campaign-list">
          <div class="campaign-item">
            <div class="campaign-rank campaign-rank--1">1</div>
            <div class="campaign-info">
              <span class="campaign-name">Maratón Navideño</span>
              <span class="campaign-units">342 unidades colectadas</span>
            </div>
            <span class="campaign-growth">+12%</span>
          </div>
          <div class="campaign-item">
            <div class="campaign-rank campaign-rank--2">2</div>
            <div class="campaign-info">
              <span class="campaign-name">Universitarios x la Vida</span>
              <span class="campaign-units">210 unidades colectadas</span>
            </div>
            <span class="campaign-growth">+5%</span>
          </div>
          <div class="campaign-item">
            <div class="campaign-rank campaign-rank--3">3</div>
            <div class="campaign-info">
              <span class="campaign-name">Donantes en Red</span>
              <span class="campaign-units">185 unidades colectadas</span>
            </div>
            <span class="campaign-growth">+2%</span>
          </div>
        </div>
        <a href="/center/campaigns" class="view-all-link">Ver todas las campañas</a>
      </div>
    </div>

    <div class="recurrent-panel">
      <div class="recurrent-header">
        <div>
          <h2 class="panel-title">Donantes más Recurrentes</h2>
          <p class="panel-subtitle">Nuestros héroes más constantes del último período.</p>
        </div>
        <button class="btn-download">Descargar Reporte</button>
      </div>
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>DONANTE</th>
              <th>TIPO</th>
              <th>ÚLTIMA DONACIÓN</th>
              <th>DONACIONES TOTALES</th>
              <th>ESTATUS</th>
              <th>ACCIÓN</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--red">RM</div>
                  <div class="donor-info">
                    <span class="donor-name">Ricardo Mendoza</span>
                    <span class="donor-email">ricardo.m@email.com</span>
                  </div>
                </div>
              </td>
              <td><span class="blood-badge blood-badge--negative">O-</span></td>
              <td>14 Oct, 2023</td>
              <td class="td-bold">12</td>
              <td><span class="status-dot status-dot--apto"></span> Apto</td>
              <td><button class="menu-btn">⋮</button></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--blue">AS</div>
                  <div class="donor-info">
                    <span class="donor-name">Ana Sofía Torres</span>
                    <span class="donor-email">ana.st@email.com</span>
                  </div>
                </div>
              </td>
              <td><span class="blood-badge blood-badge--positive">A+</span></td>
              <td>02 Nov, 2023</td>
              <td class="td-bold">9</td>
              <td><span class="status-dot status-dot--apto"></span> Apto</td>
              <td><button class="menu-btn">⋮</button></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--green">LG</div>
                  <div class="donor-info">
                    <span class="donor-name">Lucas García</span>
                    <span class="donor-email">lucas.g@email.com</span>
                  </div>
                </div>
              </td>
              <td><span class="blood-badge blood-badge--negative">B-</span></td>
              <td>22 Sep, 2023</td>
              <td class="td-bold">8</td>
              <td><span class="status-dot status-dot--espera"></span> Espera</td>
              <td><button class="menu-btn">⋮</button></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--purple">CR</div>
                  <div class="donor-info">
                    <span class="donor-name">Carmen Rojas</span>
                    <span class="donor-email">carmen.ro@email.com</span>
                  </div>
                </div>
              </td>
              <td><span class="blood-badge blood-badge--positive">AB+</span></td>
              <td>10 Nov, 2023</td>
              <td class="td-bold">7</td>
              <td><span class="status-dot status-dot--apto"></span> Apto</td>
              <td><button class="menu-btn">⋮</button></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--orange">JM</div>
                  <div class="donor-info">
                    <span class="donor-name">Javier Morales</span>
                    <span class="donor-email">javier.m@email.com</span>
                  </div>
                </div>
              </td>
              <td><span class="blood-badge blood-badge--positive">O+</span></td>
              <td>15 Oct, 2023</td>
              <td class="td-bold">6</td>
              <td><span class="status-dot status-dot--apto"></span> Apto</td>
              <td><button class="menu-btn">⋮</button></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</DashboardLayout>

<style>
  .dashboard-page {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stock-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }

  .updated-badge {
    font-size: 0.8125rem;
    color: #bc002d;
    font-weight: 500;
    white-space: nowrap;
    margin-top: 0.25rem;
  }

  .blood-stock-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0.75rem;
  }

  .blood-card {
    background: #fff;
    border-radius: 10px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid #f1d3d2;
    text-align: center;
  }

  .blood-label {
    font-size: 0.8125rem;
    color: #6b7280;
    font-weight: 500;
  }

  .blood-count {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1f2937;
    line-height: 1;
  }

  .blood-count--critico {
    color: #bc002d;
  }

  .blood-status {
    font-size: 0.75rem;
    font-weight: 600;
  }

  .blood-status--saludable {
    color: #16a34a;
  }

  .blood-status--bajo {
    color: #ea580c;
  }

  .blood-status--critico {
    color: #bc002d;
    text-transform: uppercase;
  }

  .middle-section {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
  }

  .chart-panel {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #f1d3d2;
    padding: 1.5rem;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .panel-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
  }

  .panel-subtitle {
    font-size: 0.8125rem;
    color: #9ca3af;
    margin-top: 0.125rem;
  }

  .year-select {
    padding: 0.375rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: #374151;
    background: #fff;
    font-family: "Inter", sans-serif;
    cursor: pointer;
  }

  .chart-placeholder {
    height: 260px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    height: 220px;
    padding: 0 0.5rem;
  }

  .bar {
    flex: 1;
    background: #bc002d;
    border-radius: 4px 4px 0 0;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .bar:hover {
    opacity: 1;
  }

  .chart-labels {
    display: flex;
    justify-content: space-around;
    padding-top: 0.75rem;
    border-top: 1px solid #f1d3d2;
    margin-top: 0.5rem;
  }

  .chart-labels span {
    font-size: 0.75rem;
    color: #9ca3af;
    font-weight: 500;
  }

  .campaigns-panel {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #f1d3d2;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .campaigns-panel .panel-title {
    margin-bottom: 1.25rem;
  }

  .campaign-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .campaign-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem;
    background: #fff8f7;
    border-radius: 10px;
    border: 1px solid #fde8e7;
  }

  .campaign-rank {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .campaign-rank--1 {
    background: #bc002d;
  }

  .campaign-rank--2 {
    background: #ea580c;
  }

  .campaign-rank--3 {
    background: #d97706;
  }

  .campaign-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .campaign-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1f2937;
    line-height: 1.3;
  }

  .campaign-units {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .campaign-growth {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #16a34a;
    white-space: nowrap;
  }

  .view-all-link {
    display: block;
    text-align: center;
    margin-top: 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #bc002d;
    text-decoration: none;
  }

  .view-all-link:hover {
    text-decoration: underline;
  }

  .recurrent-panel {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #f1d3d2;
    padding: 1.5rem;
  }

  .recurrent-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
  }

  .btn-download {
    padding: 0.625rem 1.25rem;
    background: #fff;
    color: #bc002d;
    border: 1.5px solid #bc002d;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-download:hover {
    background: #bc002d;
    color: #fff;
  }

  .table-container {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1d3d2;
  }

  .data-table td {
    padding: 1rem;
    font-size: 0.875rem;
    color: #374151;
    border-bottom: 1px solid #f9fafb;
    vertical-align: middle;
  }

  .data-table tbody tr:hover {
    background: #fff8f7;
  }

  .donor-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .avatar-circle--red {
    background: #fca5a5;
    color: #991b1b;
  }

  .avatar-circle--blue {
    background: #93c5fd;
    color: #1e40af;
  }

  .avatar-circle--green {
    background: #86efac;
    color: #166534;
  }

  .avatar-circle--purple {
    background: #c4b5fd;
    color: #5b21b6;
  }

  .avatar-circle--orange {
    background: #fdba74;
    color: #9a3412;
  }

  .donor-info {
    display: flex;
    flex-direction: column;
  }

  .donor-name {
    font-weight: 600;
    color: #1f2937;
  }

  .donor-email {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .blood-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .blood-badge--positive {
    background: #dcfce7;
    color: #166534;
  }

  .blood-badge--negative {
    background: #fee2e2;
    color: #991b1b;
  }

  .td-bold {
    font-weight: 700;
  }

  .status-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status-dot::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .status-dot--apto::before {
    background: #16a34a;
  }

  .status-dot--apto {
    color: #16a34a;
  }

  .status-dot--espera::before {
    background: #ea580c;
  }

  .status-dot--espera {
    color: #ea580c;
  }

  .menu-btn {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: #9ca3af;
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
  }

  .menu-btn:hover {
    color: #374151;
  }

  @media (max-width: 1200px) {
    .blood-stock-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .middle-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .blood-stock-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stock-header {
      flex-direction: column;
      gap: 0.5rem;
    }

    .recurrent-header {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
