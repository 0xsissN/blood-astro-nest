---
import DashboardLayout from "../../layouts/dashboard-layout.astro";
import CampaignTable from "../../components/campaigns/campaign-table.astro";
import UpcomingSchedules from "../../components/campaigns/upcoming-schedules.astro";
import StockStatus from "../../components/campaigns/stock-status.astro";
import CampaignModal from "../../components/campaigns/campaign-modal.astro";
---

<DashboardLayout title="Campañas" activeSection="campañas">
  <div class="campaigns-page">
    <div class="page-header">
      <div class="header-content">
        <h1 class="page-title">Gestión de Campañas</h1>
        <p class="page-subtitle">
          Planifica, monitorea y analiza las jornadas de recolección nacional.
        </p>
      </div>
      <button class="create-btn" id="open-modal-btn">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Crear Nueva Campaña
      </button>
    </div>

    <div class="page-content">
      <div class="panel-schedules">
        <UpcomingSchedules />
      </div>
      <div class="panel-stock">
        <StockStatus />
      </div>
      <div class="panel-table">
        <CampaignTable />
      </div>
    </div>
  </div>

  <CampaignModal />
</DashboardLayout>

<script is:inline>
  (function () {
    const API_URL = "http://localhost:3000";
    const modal = document.getElementById("campaign-modal");
    const openBtn = document.getElementById("open-modal-btn");
    const closeBtn = document.getElementById("modal-close-btn");
    const cancelBtn = document.getElementById("modal-cancel-btn");
    const form = document.getElementById("campaign-form");
    const alertContainer = document.getElementById("form-alert");

    function openModal() {
      modal?.classList.add("active");
    }

    function closeModal() {
      modal?.classList.remove("active");
      form?.reset();
      if (alertContainer) alertContainer.innerHTML = "";
    }

    function showAlert(message, type) {
      if (!alertContainer) return;
      const icon =
        type === "error"
          ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>'
          : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
      alertContainer.innerHTML = `
        <div class="alert alert--${type}" role="alert">
          <span class="alert__icon">${icon}</span>
          <span class="alert__message">${message}</span>
        </div>`;
    }

    openBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    cancelBtn?.addEventListener("click", closeModal);

    modal?.addEventListener("click", function (e) {
      if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && modal?.classList.contains("active"))
        closeModal();
    });

    form?.addEventListener("submit", async function (e) {
      e.preventDefault();
      if (alertContainer) alertContainer.innerHTML = "";

      const fd = new FormData(form);
      const nombre = fd.get("nombre")?.toString().trim();
      const lugar = fd.get("lugar")?.toString().trim();
      const fechaInicio = fd.get("fechaInicio")?.toString();
      const fechaFin = fd.get("fechaFin")?.toString();

      if (!nombre || !lugar || !fechaInicio || !fechaFin) {
        showAlert("Todos los campos son obligatorios", "error");
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.setAttribute("aria-busy", "true");
      }

      try {
        const res = await fetch(`${API_URL}/campaigns`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ nombre, lugar, fechaInicio, fechaFin }),
        });

        const data = await res.json();

        if (!res.ok) {
          const msg = Array.isArray(data.message)
            ? data.message.join(", ")
            : data.message || "Error al crear la campaña";
          showAlert(msg, "error");
          return;
        }

        showAlert("Campaña creada exitosamente", "success");
        setTimeout(function () {
          closeModal();
          if (typeof window.__reloadCampaigns === "function") {
            window.__reloadCampaigns();
          } else {
            window.location.reload();
          }
        }, 800);
      } catch {
        showAlert("Error de conexión. Intente nuevamente.", "error");
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.removeAttribute("aria-busy");
        }
      }
    });
  })();
</script>

<style>
  .campaigns-page {
    max-width: 1400px;
    margin: 0 auto;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.9375rem;
    color: #6b7280;
  }

  .create-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background-color: #bc002d;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }

  .create-btn:hover {
    background-color: #a30027;
  }

  .page-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "schedules stock"
      "table table";
    gap: 1.5rem;
    align-items: start;
  }

  .panel-schedules {
    grid-area: schedules;
  }

  .panel-stock {
    grid-area: stock;
  }

  .panel-table {
    grid-area: table;
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .page-content {
      grid-template-columns: 1fr;
      grid-template-areas:
        "schedules"
        "stock"
        "table";
    }
  }

  @media (max-width: 640px) {
    .page-header {
      flex-direction: column;
      gap: 1rem;
    }

    .create-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
