---
import DashboardLayout from "../../layouts/dashboard-layout.astro";
---

<DashboardLayout title="Donantes" activeSection="donantes">
  <div class="donors-page">

    <div class="page-header">
      <div>
        <h1 class="page-title">Gestión de Donantes</h1>
        <p class="page-subtitle">Administre la base de datos nacional de donantes voluntarios.</p>
      </div>
      <button class="btn-register">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="8.5" cy="7" r="4"></circle>
          <line x1="20" y1="8" x2="20" y2="14"></line>
          <line x1="23" y1="11" x2="17" y2="11"></line>
        </svg>
        Registrar Nuevo Donante
      </button>
    </div>

    <div class="filters-row">
      <div class="filter-panel">
        <h3 class="filter-title">Filtrar por Tipo Sanguíneo</h3>
        <div class="blood-filter-grid">
          <button class="blood-chip">A+</button>
          <button class="blood-chip">A-</button>
          <button class="blood-chip">B+</button>
          <button class="blood-chip">B-</button>
          <button class="blood-chip">AB+</button>
          <button class="blood-chip">AB-</button>
          <button class="blood-chip">O+</button>
          <button class="blood-chip">O-</button>
        </div>
      </div>

      <div class="stats-panel">
        <div class="stat-item">
          <span class="stat-label">Total Donantes</span>
          <span class="stat-value">12,482</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">Donantes Activos</span>
          <span class="stat-value stat-value--active">8,920</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">Nuevos este mes</span>
          <span class="stat-value stat-value--new">+142</span>
        </div>
        <button class="filter-icon-btn" title="Filtros avanzados">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="21" x2="4" y2="14"></line>
            <line x1="4" y1="10" x2="4" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12" y2="3"></line>
            <line x1="20" y1="21" x2="20" y2="16"></line>
            <line x1="20" y1="12" x2="20" y2="3"></line>
            <line x1="1" y1="14" x2="7" y2="14"></line>
            <line x1="9" y1="8" x2="15" y2="8"></line>
            <line x1="17" y1="16" x2="23" y2="16"></line>
          </svg>
        </button>
      </div>
    </div>

    <div class="table-card">
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>Donante</th>
              <th>Cédula Identidad</th>
              <th>Tipo Sanguíneo</th>
              <th>Última Donación</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--blue">AR</div>
                  <div class="donor-info">
                    <span class="donor-name">Alejandro Rodríguez</span>
                    <span class="donor-email">alejandro.rod@email.com</span>
                  </div>
                </div>
              </td>
              <td>1.234.567-8</td>
              <td><span class="blood-badge blood-badge--positive">O+</span></td>
              <td>15 May 2023</td>
              <td><span class="status-tag status-tag--activo">ACTIVO</span></td>
              <td></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--red">LM</div>
                  <div class="donor-info">
                    <span class="donor-name">Lucía Martínez</span>
                    <span class="donor-email">l.martinez@email.com</span>
                  </div>
                </div>
              </td>
              <td>4.567.890-1</td>
              <td><span class="blood-badge blood-badge--negative">A-</span></td>
              <td>02 Feb 2023</td>
              <td><span class="status-tag status-tag--activo">ACTIVO</span></td>
              <td></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--purple">CG</div>
                  <div class="donor-info">
                    <span class="donor-name">Carlos García</span>
                    <span class="donor-email">cgarcia.ph@email.com</span>
                  </div>
                </div>
              </td>
              <td>3.421.987-5</td>
              <td><span class="blood-badge blood-badge--positive">B+</span></td>
              <td>12 Dic 2022</td>
              <td><span class="status-tag status-tag--inactivo">INACTIVO</span></td>
              <td></td>
            </tr>
            <tr>
              <td>
                <div class="donor-cell">
                  <div class="avatar-circle avatar-circle--green">MV</div>
                  <div class="donor-info">
                    <span class="donor-name">Mariana Villalba</span>
                    <span class="donor-email">mariana.v@email.com</span>
                  </div>
                </div>
              </td>
              <td>2.983.412-0</td>
              <td><span class="blood-badge blood-badge--positive">AB+</span></td>
              <td>28 Jun 2023</td>
              <td><span class="status-tag status-tag--activo">ACTIVO</span></td>
              <td></td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination-bar">
        <span class="pagination-info">Mostrando 1-4 de 12,482 donantes</span>
        <div class="pagination-buttons">
          <button class="page-btn" disabled>&lt;</button>
          <button class="page-btn page-btn--active">1</button>
          <button class="page-btn">2</button>
          <button class="page-btn">3</button>
          <button class="page-btn">&gt;</button>
        </div>
      </div>
    </div>

  </div>
</DashboardLayout>

<style>
  .donors-page {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.9375rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }

  .btn-register {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background-color: #bc002d;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }

  .btn-register:hover {
    background-color: #a30027;
  }

  .filters-row {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .filter-panel {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .filter-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.875rem;
  }

  .blood-filter-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .blood-chip {
    padding: 0.375rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    background: #fff;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
    transition: all 0.15s;
  }

  .blood-chip:hover {
    border-color: #bc002d;
    color: #bc002d;
    background: #fff8f7;
  }

  .stats-panel {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: #6b7280;
    font-weight: 500;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    line-height: 1.2;
  }

  .stat-value--active {
    color: #bc002d;
  }

  .stat-value--new {
    color: #16a34a;
  }

  .filter-icon-btn {
    margin-left: auto;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    color: #6b7280;
    cursor: pointer;
    transition: all 0.15s;
    flex-shrink: 0;
  }

  .filter-icon-btn:hover {
    background: #f3f4f6;
    color: #1f2937;
  }

  .table-card {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    overflow: hidden;
  }

  .table-container {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    background: #fff8f7;
    border-bottom: 1px solid #f1d3d2;
  }

  .data-table td {
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: #374151;
    border-bottom: 1px solid #f9fafb;
    vertical-align: middle;
  }

  .data-table tbody tr:hover {
    background: #fff8f7;
  }

  .donor-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .avatar-circle {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .avatar-circle--red {
    background: #fca5a5;
    color: #991b1b;
  }

  .avatar-circle--blue {
    background: #93c5fd;
    color: #1e40af;
  }

  .avatar-circle--green {
    background: #86efac;
    color: #166534;
  }

  .avatar-circle--purple {
    background: #c4b5fd;
    color: #5b21b6;
  }

  .avatar-circle--orange {
    background: #fdba74;
    color: #9a3412;
  }

  .donor-info {
    display: flex;
    flex-direction: column;
  }

  .donor-name {
    font-weight: 600;
    color: #1f2937;
  }

  .donor-email {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .blood-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .blood-badge--positive {
    background: #fee2e2;
    color: #991b1b;
  }

  .blood-badge--negative {
    background: #fee2e2;
    color: #991b1b;
  }

  .status-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .status-tag--activo {
    background: #dcfce7;
    color: #166534;
  }

  .status-tag--inactivo {
    background: #fee2e2;
    color: #991b1b;
  }

  .pagination-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-top: 1px solid #f1d3d2;
  }

  .pagination-info {
    font-size: 0.8125rem;
    color: #6b7280;
  }

  .pagination-buttons {
    display: flex;
    gap: 0.375rem;
  }

  .page-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    color: #374151;
    cursor: pointer;
    transition: all 0.15s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: #bc002d;
    color: #bc002d;
  }

  .page-btn--active {
    background: #bc002d;
    color: #fff;
    border-color: #bc002d;
  }

  .page-btn--active:hover {
    background: #a30027;
    color: #fff;
  }

  .page-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  @media (max-width: 1024px) {
    .filters-row {
      grid-template-columns: 1fr;
    }

    .page-header {
      flex-direction: column;
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .stats-panel {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .btn-register {
      width: 100%;
      justify-content: center;
    }
  }
</style>
