---
import DashboardLayout from "../../layouts/dashboard-layout.astro";
---

<DashboardLayout title="Reportes" activeSection="reportes">
  <div class="reports-page">

    <div class="page-header-row">
      <div>
        <span class="epic-badge">ÉPICA 7: CENTRO DE ANALÍTICA</span>
        <h1 class="page-title">Gestión de Reportes</h1>
        <p class="page-subtitle">Analice la eficiencia del sistema, supervise los niveles críticos de stock y documente cada flujo de donación para el cumplimiento institucional.</p>
      </div>
      <button class="btn-history">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        Historial Completo
      </button>
    </div>

    <div class="reports-grid">
      <div class="main-column">
        <div class="report-filters-card">
          <div class="card-header-row">
            <div class="card-header-left">
              <div class="card-icon card-icon--red">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="20" x2="18" y2="10"></line>
                  <line x1="12" y1="20" x2="12" y2="4"></line>
                  <line x1="6" y1="20" x2="6" y2="14"></line>
                </svg>
              </div>
              <div>
                <h2 class="card-title">Reportes de Donaciones</h2>
                <p class="card-subtitle">Filtros dinámicos de captación (HU-20)</p>
              </div>
            </div>
            <button class="btn-generate-pdf">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
              </svg>
              Generar Reporte PDF
            </button>
          </div>

          <div class="filters-form">
            <div class="form-group">
              <label class="form-label">Rango de Fecha</label>
              <input type="date" class="form-input" />
            </div>
            <div class="form-group">
              <label class="form-label">Tipo de Sangre</label>
              <select class="form-select">
                <option>Todos los tipos</option>
                <option>A+</option>
                <option>A-</option>
                <option>B+</option>
                <option>B-</option>
                <option>AB+</option>
                <option>AB-</option>
                <option>O+</option>
                <option>O-</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Sede / Centro</label>
              <select class="form-select">
                <option>Todas las sedes</option>
                <option>Sede Central</option>
                <option>Sede Norte</option>
                <option>Sede Sur</option>
              </select>
            </div>
          </div>

          <div class="chart-preview">
            <div class="chart-placeholder-content">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d4a0a0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
              </svg>
              <p class="chart-text">Previsualización del gráfico de tendencias de donación</p>
              <p class="chart-hint">Seleccione filtros para cargar la analítica visual en tiempo real</p>
            </div>
          </div>
        </div>

        <div class="recent-reports-card">
          <div class="recent-header">
            <div class="recent-header-left">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#bc002d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <h2 class="panel-title">Reportes Generados Recientemente</h2>
            </div>
            <span class="recent-count">Mostrando últimos 5</span>
          </div>

          <div class="table-container">
            <table class="data-table">
              <thead>
                <tr>
                  <th>NOMBRE DEL REPORTE</th>
                  <th>TIPO</th>
                  <th>FECHA GENERACIÓN</th>
                  <th>USUARIO</th>
                  <th>ACCIONES</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="td-bold">Consolidado_Mensual_Julio_2024.pdf</td>
                  <td><span class="type-tag type-tag--donaciones">DONACIONES</span></td>
                  <td>01/08/2024 - 08:30 AM</td>
                  <td>
                    <div class="user-cell">
                      <div class="mini-avatar">AH</div>
                      <span>Admin Hemocentro</span>
                    </div>
                  </td>
                  <td><button class="download-btn" title="Descargar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                  </button></td>
                </tr>
                <tr>
                  <td class="td-bold">Stock_Crítico_SedeCentral_Q3.pdf</td>
                  <td><span class="type-tag type-tag--inventario">INVENTARIO</span></td>
                  <td>30/07/2024 - 04:45 PM</td>
                  <td>
                    <div class="user-cell">
                      <div class="mini-avatar mini-avatar--green">LM</div>
                      <span>L. Martínez</span>
                    </div>
                  </td>
                  <td><button class="download-btn" title="Descargar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                  </button></td>
                </tr>
                <tr>
                  <td class="td-bold">Eficiencia_Captacion_Movil_B.pdf</td>
                  <td><span class="type-tag type-tag--campana">CAMPAÑA</span></td>
                  <td>28/07/2024 - 11:20 AM</td>
                  <td>
                    <div class="user-cell">
                      <div class="mini-avatar">AH</div>
                      <span>Admin Hemocentro</span>
                    </div>
                  </td>
                  <td><button class="download-btn" title="Descargar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                  </button></td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="load-more-bar">
            <button class="load-more-btn">Cargar registros anteriores...</button>
          </div>
        </div>
      </div>

      <div class="side-column">
        <div class="stock-critico-card">
          <div class="stock-header-row">
            <div class="stock-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
              </svg>
            </div>
            <div>
              <h3 class="stock-title">Stock Crítico</h3>
              <p class="stock-subtitle">Estado actual de inventario (HU-21)</p>
            </div>
          </div>

          <div class="alert-filter-row">
            <span class="filter-label">Filtros de Alerta</span>
            <span class="alert-badge">ALERTA CADUCIDAD ACTIVA</span>
          </div>

          <select class="form-select full-width">
            <option>Todos los Grupos Críticos</option>
            <option>O Negativo</option>
            <option>A Negativo</option>
            <option>B Negativo</option>
          </select>

          <div class="critical-list">
            <div class="critical-item critical-item--warning">
              <div class="critical-badge">O-</div>
              <div class="critical-info">
                <span class="critical-name">O Negativo</span>
                <span class="critical-detail critical-detail--warning">▲ 12 unidades por vencer</span>
              </div>
              <span class="critical-units">45u</span>
            </div>
            <div class="critical-item critical-item--ok">
              <div class="critical-badge">A+</div>
              <div class="critical-info">
                <span class="critical-name">A Positivo</span>
                <span class="critical-detail critical-detail--ok">Estado: Óptimo</span>
              </div>
              <span class="critical-units">128u</span>
            </div>
            <div class="critical-item critical-item--danger">
              <div class="critical-badge critical-badge--danger">B-</div>
              <div class="critical-info">
                <span class="critical-name">B Negativo</span>
                <span class="critical-detail critical-detail--danger">▲ Stock mínimo</span>
              </div>
              <span class="critical-units critical-units--danger">08u</span>
            </div>
          </div>

          <button class="btn-export">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Exportar Inventario PDF
          </button>
        </div>
      </div>
    </div>

    <button class="fab-btn" title="Nuevo reporte">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
    </button>

  </div>
</DashboardLayout>

<style>
  .reports-page {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  .page-header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .epic-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #bc002d;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.375rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.9375rem;
    color: #6b7280;
    margin-top: 0.375rem;
    max-width: 640px;
    line-height: 1.5;
  }

  .btn-history {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: #fff;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-history:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }

  .reports-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 1.5rem;
    align-items: start;
  }

  .main-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .report-filters-card {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .card-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .card-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-icon--red {
    background: #fee2e2;
    color: #bc002d;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1f2937;
  }

  .card-subtitle {
    font-size: 0.8125rem;
    color: #9ca3af;
  }

  .btn-generate-pdf {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: #bc002d;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .btn-generate-pdf:hover {
    background: #a30027;
  }

  .filters-form {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #374151;
  }

  .form-input,
  .form-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    color: #374151;
    background: #fff;
    width: 100%;
  }

  .form-input:focus,
  .form-select:focus {
    outline: none;
    border-color: #bc002d;
    box-shadow: 0 0 0 2px rgba(188, 0, 45, 0.1);
  }

  .chart-preview {
    border: 2px dashed #e5e7eb;
    border-radius: 12px;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chart-placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .chart-text {
    font-size: 0.875rem;
    color: #6b7280;
    font-weight: 500;
  }

  .chart-hint {
    font-size: 0.8125rem;
    color: #9ca3af;
  }

  .recent-reports-card {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    overflow: hidden;
  }

  .recent-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #f1d3d2;
  }

  .recent-header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .panel-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1f2937;
  }

  .recent-count {
    font-size: 0.8125rem;
    color: #9ca3af;
  }

  .table-container {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid #f1d3d2;
  }

  .data-table td {
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: #374151;
    border-bottom: 1px solid #f9fafb;
    vertical-align: middle;
  }

  .data-table tbody tr:hover {
    background: #fff8f7;
  }

  .td-bold {
    font-weight: 600;
    color: #1f2937;
  }

  .type-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    border-radius: 4px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .type-tag--donaciones {
    background: #dbeafe;
    color: #1e40af;
  }

  .type-tag--inventario {
    background: #fee2e2;
    color: #991b1b;
  }

  .type-tag--campana {
    background: #d1fae5;
    color: #065f46;
  }

  .user-cell {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mini-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #e0e7ff;
    color: #3730a3;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .mini-avatar--green {
    background: #dcfce7;
    color: #166534;
  }

  .download-btn {
    background: none;
    border: none;
    color: #bc002d;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .download-btn:hover {
    background: #fee2e2;
  }

  .load-more-bar {
    padding: 0.875rem;
    text-align: center;
    border-top: 1px solid #f1d3d2;
  }

  .load-more-btn {
    background: none;
    border: none;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #bc002d;
    cursor: pointer;
  }

  .load-more-btn:hover {
    text-decoration: underline;
  }

  .side-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stock-critico-card {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .stock-header-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .stock-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: #fee2e2;
    color: #bc002d;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .stock-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1f2937;
  }

  .stock-subtitle {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .alert-filter-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.625rem;
  }

  .filter-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #374151;
  }

  .alert-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #bc002d;
    background: #fee2e2;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .full-width {
    width: 100%;
    margin-bottom: 1rem;
  }

  .critical-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .critical-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 8px;
  }

  .critical-item--warning {
    background: #fffbeb;
    border: 1px solid #fde68a;
  }

  .critical-item--ok {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
  }

  .critical-item--danger {
    background: #fef2f2;
    border: 1px solid #fecaca;
  }

  .critical-badge {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #374151;
    flex-shrink: 0;
  }

  .critical-badge--danger {
    border-color: #bc002d;
    color: #bc002d;
  }

  .critical-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .critical-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1f2937;
  }

  .critical-detail {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .critical-detail--warning {
    color: #d97706;
  }

  .critical-detail--ok {
    color: #16a34a;
  }

  .critical-detail--danger {
    color: #dc2626;
  }

  .critical-units {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
    flex-shrink: 0;
  }

  .critical-units--danger {
    color: #dc2626;
  }

  .btn-export {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem;
    background: #bc002d;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-export:hover {
    background: #a30027;
  }

  .fab-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: #bc002d;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(188, 0, 45, 0.3);
    transition: background 0.15s, transform 0.15s;
    z-index: 10;
  }

  .fab-btn:hover {
    background: #a30027;
