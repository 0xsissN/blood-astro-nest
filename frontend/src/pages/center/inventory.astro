---
import DashboardLayout from "../../layouts/dashboard-layout.astro";
---

<DashboardLayout title="Inventario" activeSection="inventario">
  <div class="inventory-page">

    <div class="page-header">
      <div>
        <h1 class="page-title">Control de Inventario</h1>
        <p class="page-subtitle">Monitoreo en tiempo real de unidades sanguíneas disponibles.</p>
      </div>
      <button class="btn-update">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
        </svg>
        Actualizar Inventario Manual
      </button>
    </div>

    <div class="summary-cards">
      <div class="summary-card summary-card--suficiente">
        <div class="summary-top">
          <span class="summary-type">Tipo A+</span>
          <span class="summary-status summary-status--suficiente">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Suficiente
          </span>
        </div>
        <div class="summary-count">
          <span class="count-number">42</span>
          <span class="count-label">bolsas</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill progress-fill--green" style="width:80%"></div>
        </div>
      </div>

      <div class="summary-card summary-card--bajo">
        <div class="summary-top">
          <span class="summary-type">Tipo O-</span>
          <span class="summary-status summary-status--bajo">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            Bajo
          </span>
        </div>
        <div class="summary-count">
          <span class="count-number count-number--bajo">08</span>
          <span class="count-label">bolsas</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill progress-fill--orange" style="width:35%"></div>
        </div>
      </div>

      <div class="summary-card summary-card--critico">
        <div class="summary-top">
          <span class="summary-type">Tipo AB-</span>
          <span class="summary-status summary-status--critico">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="15" y1="9" x2="9" y2="15"></line>
              <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
            Critico
          </span>
        </div>
        <div class="summary-count">
          <span class="count-number count-number--critico">03</span>
          <span class="count-label">bolsas</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill progress-fill--red" style="width:15%"></div>
        </div>
      </div>

      <div class="summary-card summary-card--suficiente">
        <div class="summary-top">
          <span class="summary-type">Tipo B+</span>
          <span class="summary-status summary-status--suficiente">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Suficiente
          </span>
        </div>
        <div class="summary-count">
          <span class="count-number">26</span>
          <span class="count-label">bolsas</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill progress-fill--green" style="width:60%"></div>
        </div>
      </div>
    </div>

    <div class="detail-card">
      <div class="detail-header">
        <h2 class="panel-title">Stock Detallado</h2>
        <select class="form-select">
          <option>Todos los Grupos</option>
          <option>A+</option>
          <option>A-</option>
          <option>B+</option>
          <option>B-</option>
          <option>AB+</option>
          <option>AB-</option>
          <option>O+</option>
          <option>O-</option>
        </select>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>GRUPO SANGUÍNEO</th>
              <th>RH</th>
              <th>UNIDADES</th>
              <th>ESTADO</th>
              <th>PRÓXIMO VENCIMIENTO</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="td-bold">A</td>
              <td><span class="rh-positive">+ (Positivo)</span></td>
              <td class="td-bold">42 bolsas</td>
              <td><span class="status-dot status-dot--suficiente"></span> Suficiente</td>
              <td>12/11/2023</td>
            </tr>
            <tr>
              <td class="td-bold">A</td>
              <td><span class="rh-negative">- (Negativo)</span></td>
              <td class="td-bold">15 bolsas</td>
              <td><span class="status-dot status-dot--suficiente"></span> Suficiente</td>
              <td>08/11/2023</td>
            </tr>
            <tr>
              <td class="td-bold">O</td>
              <td><span class="rh-positive">+ (Positivo)</span></td>
              <td class="td-bold">12 bolsas</td>
              <td><span class="status-dot status-dot--bajo"></span> Bajo</td>
              <td>05/11/2023</td>
            </tr>
            <tr>
              <td class="td-bold">O</td>
              <td><span class="rh-negative">- (Negativo)</span></td>
              <td class="td-bold">08 bolsas</td>
              <td><span class="status-dot status-dot--bajo"></span> Bajo</td>
              <td>03/11/2023</td>
            </tr>
            <tr>
              <td class="td-bold">B</td>
              <td><span class="rh-positive">+ (Positivo)</span></td>
              <td class="td-bold">26 bolsas</td>
              <td><span class="status-dot status-dot--suficiente"></span> Suficiente</td>
              <td>15/11/2023</td>
            </tr>
            <tr>
              <td class="td-bold">AB</td>
              <td><span class="rh-negative">- (Negativo)</span></td>
              <td class="td-bold td-bold--critico">03 bolsas</td>
              <td><span class="status-dot status-dot--critico"></span> Crítico</td>
              <td>28/10/2023</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</DashboardLayout>

<style>
  .inventory-page {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.9375rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }

  .btn-update {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background-color: #bc002d;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }

  .btn-update:hover {
    background-color: #a30027;
  }

  .summary-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .summary-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border: 1px solid #f1d3d2;
    border-top: 3px solid transparent;
  }

  .summary-card--suficiente {
    border-top-color: #16a34a;
  }

  .summary-card--bajo {
    border-top-color: #ea580c;
  }

  .summary-card--critico {
    border-top-color: #dc2626;
  }

  .summary-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .summary-type {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #374151;
    background: #f3f4f6;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
  }

  .summary-status {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .summary-status--suficiente {
    color: #16a34a;
  }

  .summary-status--bajo {
    color: #ea580c;
  }

  .summary-status--critico {
    color: #dc2626;
  }

  .summary-count {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
  }

  .count-number {
    font-size: 2.25rem;
    font-weight: 700;
    color: #1f2937;
    line-height: 1;
  }

  .count-number--bajo {
    color: #1f2937;
  }

  .count-number--critico {
    color: #dc2626;
  }

  .count-label {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .progress-bar {
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  .progress-fill--green {
    background: #16a34a;
  }

  .progress-fill--orange {
    background: #ea580c;
  }

  .progress-fill--red {
    background: #dc2626;
  }

  .detail-card {
    background: #fff;
    border: 1px solid #f1d3d2;
    border-radius: 12px;
    overflow: hidden;
  }

  .detail-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #f1d3d2;
  }

  .panel-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
  }

  .form-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: "Inter", sans-serif;
    font-size: 0.8125rem;
    color: #374151;
    background: #fff;
    cursor: pointer;
  }

  .form-select:focus {
    outline: none;
    border-color: #bc002d;
  }

  .table-container {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.875rem 1.5rem;
    background: #fff8f7;
    border-bottom: 1px solid #f1d3d2;
  }

  .data-table td {
    padding: 1rem 1.5rem;
    font-size: 0.875rem;
    color: #374151;
    border-bottom: 1px solid #f9fafb;
    vertical-align: middle;
  }

  .data-table tbody tr:hover {
    background: #fff8f7;
  }

  .td-bold {
    font-weight: 700;
    color: #1f2937;
  }

  .td-bold--critico {
    color: #dc2626;
  }

  .rh-positive {
    color: #dc2626;
    font-weight: 500;
  }

  .rh-negative {
    color: #dc2626;
    font-weight: 500;
  }

  .status-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status-dot::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .status-dot--suficiente::before {
    background: #16a34a;
  }

  .status-dot--suficiente {
    color: #16a34a;
  }

  .status-dot--bajo::before {
    background: #ea580c;
  }

  .status-dot--bajo {
    color: #ea580c;
  }

  .status-dot--critico::before {
    background: #dc2626;
  }

  .status-dot--critico {
    color: #dc2626;
  }

  @media (max-width: 1024px) {
    .summary-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .summary-cards {
      grid-template-columns: 1fr;
    }

    .page-header {
      flex-direction: column;
      gap: 1rem;
    }

    .btn-update {
      width: 100%;
      justify-content: center;
    }

    .detail-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
