---
import PublicLayout from "../layouts/public-layout.astro";
import HeroSection from "../components/public/hero-section.astro";
import InfoCard from "../components/public/info-card.astro";
---

<PublicLayout
  title="Contacto - Hemocentro"
  description="Ponte en contacto con el Hemocentro. Encuentra dirección, teléfono, correo electrónico y horarios de atención."
>
  <HeroSection
    title="Contáctanos"
    subtitle="Estamos para ayudarte. Si tienes dudas sobre la donación de sangre o deseas más información, no dudes en escribirnos."
  />

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <div
            class="text-center"
            style="margin-bottom: 2.5rem; text-align: left;"
          >
            <h2 class="section-title">Información de contacto</h2>
            <p class="section-subtitle" style="max-width: none;">
              Puedes visitarnos, llamarnos o enviarnos un correo electrónico.
            </p>
          </div>

          <div class="grid-2">
            <InfoCard
              icon="phone"
              title="Teléfono"
              description="+1 (809) 555-1234"
            />
            <InfoCard
              icon="phone"
              title="WhatsApp"
              description="+1 (809) 555-5678"
            />
            <InfoCard
              icon="clipboard"
              title="Correo electrónico"
              description="contacto@hemocentro.gob.do"
            />
            <InfoCard
              icon="heart"
              title="Dirección"
              description="Av. Principal #123, Centro Médico Nacional, Santo Domingo"
            />
          </div>

          <div class="card" style="margin-top: 2rem;">
            <h3
              style="font-size: 1.125rem; font-weight: 600; color: #281717; margin-bottom: 1rem;"
            >
              Horarios de atención
            </h3>
            <table class="schedule-table">
              <tbody>
                <tr><td>Lunes a Viernes</td><td>8:00 AM - 6:00 PM</td></tr>
                <tr><td>Sábados</td><td>8:00 AM - 2:00 PM</td></tr>
                <tr><td>Domingos y Festivos</td><td>Cerrado</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 968px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
  }

  .schedule-table td {
    padding: 0.75rem 0;
    border-bottom: 1px solid #e4bdbc;
    font-size: 0.9375rem;
    color: #5c403f;
  }

  .schedule-table td:last-child {
    text-align: right;
    font-weight: 500;
    color: #281717;
  }

  .schedule-table tr:last-child td {
    border-bottom: none;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form__title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #281717;
  }

  .contact-form__desc {
    font-size: 0.9375rem;
    color: #5c403f;
    margin-top: -0.75rem;
  }

  .contact-form__group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-form__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #5c403f;
  }

  .contact-form__input {
    padding: 0.75rem 1rem;
    font-family: "Inter", sans-serif;
    font-size: 0.9375rem;
    color: #281717;
    background-color: #fff8f7;
    border: 1px solid #e4bdbc;
    border-radius: 0.75rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    width: 100%;
  }

  .contact-form__input:focus {
    outline: none;
    border-color: #bc002d;
    box-shadow: 0 0 0 3px rgba(188, 0, 45, 0.1);
  }

  .contact-form__input::placeholder {
    color: #9ca3af;
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .alert {
    padding: 0.875rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .alert--success {
    background-color: rgba(16, 185, 129, 0.1);
    color: #059669;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .alert--error {
    background-color: rgba(188, 0, 45, 0.08);
    color: #bc002d;
    border: 1px solid rgba(188, 0, 45, 0.15);
  }

  @media (max-width: 767px) {
    .contact-grid {
      gap: 2rem;
    }
  }
</style>
