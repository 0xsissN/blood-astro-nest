---
import PublicLayout from '../layouts/public-layout.astro';
import HeroSection from '../components/public/hero-section.astro';
import InfoCard from '../components/public/info-card.astro';

const campaigns = [
  {
    title: 'Campaña de Verano 2026',
    place: 'Hospital Regional, Santo Domingo',
    date: '15 - 30 Julio 2026',
    time: '8:00 AM - 4:00 PM',
    status: 'Próximamente',
    type: 'green',
  },
  {
    title: 'Jornada Empresarial',
    place: 'Edificio Corporativo BHD, Santiago',
    date: '5 - 7 Agosto 2026',
    time: '9:00 AM - 5:00 PM',
    status: 'Próximamente',
    type: 'green',
  },
  {
    title: 'Donatón Universitaria',
    place: 'Universidad Autónoma, Recinto Central',
    date: '20 - 22 Junio 2026',
    time: '8:00 AM - 6:00 PM',
    status: 'Activa',
    type: 'orange',
  },
  {
    title: 'Campaña Nacional de Sangre',
    place: 'Centro de Convenciones, Punta Cana',
    date: '1 - 5 Marzo 2026',
    time: '8:00 AM - 3:00 PM',
    status: 'Finalizada',
    type: 'red',
  },
];
---

<PublicLayout title="Campañas - Hemocentro" description="Conoce las campañas de donación de sangre activas y próximas del Hemocentro.">
  <HeroSection
    title="Campañas de Donación"
    subtitle="Mantente informado sobre las jornadas de donación organizadas por el Hemocentro y sus aliados. Tu participación puede marcar la diferencia."
    ctaText="Ver requisitos para donar"
    ctaHref="/requisitos"
  />

  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 1rem;">
        <span class="tag tag--red" style="margin-bottom: 1rem; display: inline-block;">Calendario de campañas</span>
        <h2 class="section-title">Próximas jornadas de donación</h2>
        <p class="section-subtitle mx-auto">
          Consulta las fechas y lugares disponibles para donar sangre.
        </p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 3rem;">
        {campaigns.map((camp) => (
          <article class="campaign-card card">
            <div class="campaign-card__body">
              <div class="campaign-card__info">
                <span class:list={['tag', camp.type === 'green' ? 'tag--green' : camp.type === 'orange' ? 'tag--orange' : 'tag--red']}>{camp.status}</span>
                <h3 class="campaign-card__title">{camp.title}</h3>
                <div class="campaign-card__details">
                  <span class="campaign-card__detail">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {camp.place}
                  </span>
                  <span class="campaign-card__detail">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {camp.date}
                  </span>
                  <span class="campaign-card__detail">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {camp.time}
                  </span>
                </div>
              </div>
              <div class="campaign-card__action">
                <a href="/requisitos" class="btn-primary" style="padding: 0.625rem 1.5rem; font-size: 0.875rem;">
                  {camp.status === 'Finalizada' ? 'Ver detalles' : 'Participar'}
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <h2 class="section-title">¿Cómo participar?</h2>
        <p class="section-subtitle mx-auto">
          Participar en una campaña es sencillo. Solo sigue estos pasos.
        </p>
      </div>
      <div class="grid-3">
        <InfoCard
          icon="clipboard"
          title="1. Verifica requisitos"
          description="Asegúrate de cumplir con los requisitos básicos para donar sangre."
        />
        <InfoCard
          icon="calendar"
          title="2. Elige una campaña"
          description="Selecciona la campaña más cercana a tu ubicación y regístrate."
        />
        <InfoCard
          icon="users"
          title="3. Asiste y dona"
          description="Acude el día de la campaña con tu documento de identidad. El proceso dura aproximadamente 30 minutos."
        />
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .campaign-card__body {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .campaign-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .campaign-card__title {
    font-size: 1.1875rem;
    font-weight: 600;
    color: #281717;
  }

  .campaign-card__details {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .campaign-card__detail {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: #5c403f;
  }

  .campaign-card__detail svg {
    flex-shrink: 0;
  }

  .campaign-card__action {
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .campaign-card__body {
      flex-direction: column;
    }

    .campaign-card__details {
      flex-direction: column;
      gap: 0.625rem;
    }

    .campaign-card__action {
      width: 100%;
    }

    .campaign-card__action a {
      width: 100%;
      text-align: center;
    }
  }
</style>
