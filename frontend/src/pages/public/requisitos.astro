---
import PublicLayout from "../../layouts/public-layout.astro";
import InfoCard from "../../components/public/info-card.astro";

const requirements = [
  {
    title: "Edad",
    description:
      "Tener entre 18 y 65 años. Los menores de edad pueden donar con autorización de sus padres o tutores.",
  },
  {
    title: "Peso",
    description:
      "Pesar mínimo 50 kg (110 lb). Este requisito garantiza que la donación no afecte tu salud.",
  },
  {
    title: "Salud",
    description:
      "Gozar de buena salud general. No estar resfriado, gripado o con alguna infección activa.",
  },
  {
    title: "Alimentación",
    description:
      "Haber desayunado o almorzado liviano. Evitar alimentos grasos antes de la donación.",
  },
  {
    title: "Descanso",
    description:
      "Haber dormido al menos 6 horas la noche anterior. No haber realizado ejercicio extenuante.",
  },
  {
    title: "Intervalo",
    description:
      "Esperar al menos 3 meses entre donaciones. No haber donado sangre en los últimos 90 días.",
  },
];

const restrictions = [
  "Haber tenido cirugía mayor en los últimos 6 meses.",
  "Estar embarazada o en período de lactancia.",
  "Tener tatuajes o piercings realizados en los últimos 12 meses.",
  "Consumir drogas intravenosas.",
  "Padecer enfermedades crónicas (diabetes, hipertensión no controlada, epilepsia).",
  "Haber recibido transfusiones sanguíneas en el último año.",
  "Tener hepatitis B o C, VIH/SIDA, sífilis o enfermedad de Chagas.",
  "Estar bajo tratamiento con antibióticos (esperar 7 días después de finalizar).",
];
---

<PublicLayout
  title="Requisitos para Donar Sangre - Hemocentro"
  description="Conoce los requisitos y pasos para donar sangre en el Hemocentro. Infórmate antes de tu donación."
>
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 2rem;">
        <h2 class="section-title">Requisitos básicos para donar</h2>
        <p class="section-subtitle mx-auto">
          Antes de donar, asegúrate de cumplir con estos requisitos esenciales.
        </p>
      </div>
      <div class="grid-3">
        {
          requirements.map((req) => (
            <InfoCard
              icon="clipboard"
              title={req.title}
              description={req.description}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="text-center" style="margin-bottom: 2rem;">
        <span
          class="tag tag--orange"
          style="margin-bottom: 1rem; display: inline-block;"
          >Impedimentos temporales</span
        >
        <h2 class="section-title">Situaciones que impiden donar</h2>
        <p class="section-subtitle mx-auto">
          En algunos casos no podrás donar sangre temporal o permanentemente.
          Revisa esta lista.
        </p>
      </div>
      <div class="card" style="max-width: 800px; margin: 0 auto;">
        <ul class="restrictions-list">
          {
            restrictions.map((r) => (
              <li class="restrictions-list__item">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#bc002d"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <line x1="15" y1="9" x2="9" y2="15" />
                  <line x1="9" y1="9" x2="15" y2="15" />
                </svg>
                <span>{r}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="text-center" style="margin-top: 2rem;">
        <p style="color: #5c403f; font-size: 0.9375rem;">
          Si tienes dudas, contáctanos o consulta con el personal médico durante
          tu evaluación.
        </p>
        <a
          href="/public/preguntas-frecuentes"
          class="btn-secondary"
          style="margin-top: 1rem; display: inline-flex;"
          >Ver preguntas frecuentes</a
        >
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 2rem;">
        <h2 class="section-title">Antes de donar</h2>
      </div>
      <div class="grid-3">
        <InfoCard
          icon="clipboard"
          title="Documentación"
          description="Lleva tu cédula de identidad o pasaporte. Es indispensable para registrarte como donante."
        />
        <InfoCard
          icon="drop"
          title="Hidratación"
          description="Bebe abundante agua antes de la donación. Evita el café y las bebidas alcohólicas."
        />
        <InfoCard
          icon="heart"
          title="Tranquilidad"
          description="Relájate durante el proceso. El personal médico te acompañará en todo momento."
        />
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .restrictions-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .restrictions-list__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: #5c403f;
    line-height: 1.5;
  }

  .restrictions-list__item svg {
    flex-shrink: 0;
    margin-top: 2px;
  }
</style>
