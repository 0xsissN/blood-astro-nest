const totalCount = donors.length;
const newThisMonth = 3;
---

<DashboardLayout
  title="Gestión de Donantes - BancoVida"
  currentSection="donantes"
>
  <!-- Header -->
  <div class="page-header">
    <div>
      <h1 class="page-header__title">Gestión de Donantes</h1>
      <p class="page-header__subtitle">
        Administre la base de datos nacional de donantes voluntarios.
      </p>
    </div>
    <button
      class="btn-primary"
      id="open-create-modal"
      style="display: inline-flex; align-items: center; gap: 0.5rem;"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="12" y1="5" x2="12" y2="19"></line><line
          x1="5"
          y1="12"
          x2="19"
          y2="12"></line></svg
      >
      Registrar Nuevo Donante
    </button>
  </div>

  <!-- Filters + Stats -->
  <div class="filters-grid">
    <div class="filter-card">
      <span class="filter-card__label">Filtrar por Tipo Sanguíneo</span>
      <div class="filter-card__pills" id="blood-type-filters">
        {
          bloodTypes.map((bt) => (
            <button class="pill" data-blood={bt} type="button">
              {bt}
            </button>
          ))
        }
      </div>
    </div>
    <div class="stats-card">
      <div class="stat-item">
        <span class="stat-item__label">Total Donantes</span>
        <span class="stat-item__value">{totalCount}</span>
      </div>
      <div class="stat-item stat-item--bordered">
        <span class="stat-item__label">Donantes Activos</span>
        <span class="stat-item__value stat-item__value--primary"
          >{activeCount}</span
        >
      </div>
      <div class="stat-item stat-item--bordered">
        <span class="stat-item__label">Nuevos este mes</span>
        <span class="stat-item__value stat-item__value--secondary"
          >+{newThisMonth}</span
        >
      </div>
      <button class="stats-card__filter-btn" aria-label="Filtros avanzados">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#5c403f"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="4" y1="21" x2="4" y2="14"></line><line
            x1="4"
            y1="10"
            x2="4"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line
            x1="12"
            y1="8"
            x2="12"
            y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line
            x1="20"
            y1="12"
            x2="20"
            y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line
            x1="9"
            y1="8"
            x2="15"
            y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Table -->
  <div class="table-wrap">
    <table class="donor-table" id="donor-table">
      <thead>
        <tr>
          <th>Donante</th>
          <th>Cédula Identidad</th>
          <th>Tipo Sanguíneo</th>
          <th>Teléfono</th>
          <th>Estado</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody id="donor-table-body">
        {
          donors.map((donor) => {
            const initials = (
              donor.nombre.charAt(0) + donor.apellido.charAt(0)
            ).toUpperCase();
            return (
              <tr
                class="donor-row"
                data-id={donor.id}
                data-blood={donor.tipo_sangre}
                data-activo={donor.activo}
              >
                <td>
                  <div class="donor-cell">
                    <div class="donor-avatar">{initials}</div>
                    <div>
                      <p class="donor-name">
                        {donor.nombre} {donor.apellido}
                      </p>
                      <p class="donor-email">{donor.email}</p>
                    </div>
                  </div>
                </td>
                <td class="donor-ci">{donor.ci}</td>
                <td>
                  <span class="blood-badge">{donor.tipo_sangre}</span>
                </td>
                <td class="donor-phone">{donor.telefono}</td>
                <td>
                  <span
                    class:list={[
                      "status-badge",
                      donor.activo
                        ? "status-badge--active"
                        : "status-badge--inactive",
                    ]}
                  >
                    {donor.activo ? "Activo" : "Inactivo"}
                  </span>
                </td>
                <td class="text-right">
                  <div class="action-btns">
                    <button
                      class="action-btn"
                      title="Editar"
                      data-action="edit"
                      data-id={donor.id}
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <>
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </>
                      </svg>
                    </button>
                    <button
                      class="action-btn"
                      title="Historial"
                      data-action="history"
                      data-id={donor.id}
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <>
                          <circle cx="12" cy="12" r="10" />
                          <polyline points="12 6 12 12 16 14" />
                        </>
                      </svg>
                    </button>
                    <button
                      class="action-btn action-btn--danger"
                      title={donor.activo ? "Desactivar" : "Eliminar"}
                      data-action="delete"
                      data-id={donor.id}
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <>
                          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                          <circle cx="12" cy="7" r="4" />
                        </>
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
    <!-- Pagination -->
    <div class="pagination">
      <span class="pagination__info"
        >Mostrando 1-{donors.length} de {donors.length} donantes</span
      >
      <div class="pagination__btns">
        <button class="pagination__btn pagination__btn--active" type="button"
          >1</button
        >
      </div>
    </div>
  </div>

  <!-- Empty state (hidden by default) -->
  <div class="empty-state" id="empty-state" hidden>
    <svg
      width="64"
      height="64"
      viewBox="0 0 24 24"
      fill="none"
      stroke="#e4bdbc"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle
        cx="9"
        cy="7"
        r="4"></circle><line x1="23" y1="11" x2="17" y2="11"></line></svg
    >
    <h3 class="empty-state__title">No se encontraron donantes</h3>
    <p class="empty-state__desc">
      Intenta ajustar los filtros o registra un nuevo donante.
    </p>
  </div>

  <!-- Modal: Create / Edit Donor -->
  <div class="modal-overlay hidden" id="donor-modal">
    <div class="modal">
      <div class="modal__header">
        <h2 class="modal__title" id="modal-title">Registrar Nuevo Donante</h2>
        <button class="modal__close" id="modal-close" aria-label="Cerrar">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="18" y1="6" x2="6" y2="18"></line><line
              x1="6"
              y1="6"
              x2="18"
              y2="18"></line></svg
          >
        </button>
      </div>
      <form class="modal__form" id="donor-form" novalidate>
        <input type="hidden" id="donor-id" value="" />
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="donor-nombre">Nombre</label>
            <input
              class="form-input"
              type="text"
              id="donor-nombre"
              placeholder="Nombre"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="donor-apellido">Apellido</label>
            <input
              class="form-input"
              type="text"
              id="donor-apellido"
              placeholder="Apellido"
              required
            />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="donor-ci">Cédula de Identidad</label>
            <input
              class="form-input"
              type="text"
              id="donor-ci"
              placeholder="000.000.000-0"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="donor-fecha-nac"
              >Fecha de Nacimiento</label
            >
            <input
              class="form-input"
              type="date"
              id="donor-fecha-nac"
              required
            />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="donor-telefono">Teléfono</label>
            <input
              class="form-input"
              type="tel"
              id="donor-telefono"
              placeholder="809-555-0000"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="donor-tipo-sangre"
              >Tipo Sanguíneo</label
            >
            <select class="form-input" id="donor-tipo-sangre" required>
              <option value="">Seleccionar...</option>
              {bloodTypes.map((bt) => <option value={bt}>{bt}</option>)}
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="donor-email">Email</label>
          <input
            class="form-input"
            type="email"
            id="donor-email"
            placeholder="correo@ejemplo.com"
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="donor-direccion">Dirección</label>
          <textarea
            class="form-input form-textarea"
            id="donor-direccion"
            placeholder="Dirección completa..."
            rows="3"></textarea>
        </div>
        <div class="modal__error hidden" id="form-error"></div>
        <div class="modal__actions">
          <button class="btn-cancel" type="button" id="modal-cancel"
            >Cancelar</button
          >
          <button class="btn-primary" type="submit" id="modal-submit"
            >Guardar Donante</button
          >
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Delete Confirmation -->
  <div class="modal-overlay hidden" id="delete-modal">
    <div class="modal modal--sm">
      <div class="modal__header">
        <h2 class="modal__title">Confirmar acción</h2>
        <button
          class="modal__close"
          id="delete-modal-close"
          aria-label="Cerrar"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="18" y1="6" x2="6" y2="18"></line><line
              x1="6"
              y1="6"
              x2="18"
              y2="18"></line></svg
          >
        </button>
      </div>
      <div class="delete-content">
        <div class="delete-icon">
          <svg
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#bc002d"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="10"></circle><line
              x1="12"
              y1="8"
              x2="12"
              y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
            ></line></svg
          >
        </div>
        <p class="delete-text" id="delete-message">
          ¿Estás seguro de que deseas desactivar este donante?
        </p>
        <p class="delete-note" id="delete-note">
          Este donante posee donaciones registradas, solo podrá desactivarse.
        </p>
      </div>
      <div class="modal__actions">
        <button class="btn-cancel" type="button" id="delete-cancel"
          >Cancelar</button
        >
        <button class="btn-danger" type="button" id="delete-confirm"
          >Confirmar</button
        >
      </div>
    </div>
  </div>
</DashboardLayout>

