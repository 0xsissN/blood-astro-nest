              <div class="action-btns">
                <button class="action-btn" title="Editar" data-action="edit" data-id="${d.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="action-btn" title="Historial" data-action="history" data-id="${d.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </button>
                <button class="action-btn action-btn--danger" title="${deleteLabel}" data-action="delete" data-id="${d.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </button>
              </div>
            </td>
          </tr>`;
        })
        .join("");

      attachRowEvents();
    }

    function filterDonors() {
      let filtered = [...donors];

      if (activeBloodFilter) {
        filtered = filtered.filter((d) => d.tipo_sangre === activeBloodFilter);
      }

      const query = searchInput.value.trim().toLowerCase();
      if (query) {
        filtered = filtered.filter(
          (d) =>
            d.nombre.toLowerCase().includes(query) ||
            d.apellido.toLowerCase().includes(query) ||
            d.ci.includes(query) ||
            d.tipo_sangre.toLowerCase().includes(query),
        );
      }

      renderTable(filtered);
    }

    function attachRowEvents() {
      document.querySelectorAll('[data-action="edit"]').forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const id = parseInt(btn.dataset.id);
          openEditModal(id);
        });
      });

      document.querySelectorAll('[data-action="delete"]').forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const id = parseInt(btn.dataset.id);
          openDeleteModal(id);
        });
      });

      document.querySelectorAll('[data-action="history"]').forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          alert("Historial de donaciones - Funcionalidad próxima.");
        });
      });
    }

    function openEditModal(id) {
      const donor = donors.find((d) => d.id === id);
      if (!donor) return;
      editingId = id;
      modalTitle.textContent = "Editar Donante";
      document.getElementById("modal-submit").textContent = "Guardar Cambios";
      donorIdInput.value = id;
      document.getElementById("donor-nombre").value = donor.nombre;
      document.getElementById("donor-apellido").value = donor.apellido;
      document.getElementById("donor-ci").value = donor.ci;
      document.getElementById("donor-fecha-nac").value = donor.fecha_nacimiento;
      document.getElementById("donor-telefono").value = donor.telefono;
      document.getElementById("donor-tipo-sangre").value = donor.tipo_sangre;
      document.getElementById("donor-email").value = donor.email;
      document.getElementById("donor-direccion").value = donor.direccion;
      formError.classList.add("hidden");
      modal.classList.remove("hidden");
    }

    function openCreateModal() {
      editingId = null;
      modalTitle.textContent = "Registrar Nuevo Donante";
      document.getElementById("modal-submit").textContent = "Guardar Donante";
      donorForm.reset();
      donorIdInput.value = "";
      formError.classList.add("hidden");
      modal.classList.remove("hidden");
    }

    function openDeleteModal(id) {
      const donor = donors.find((d) => d.id === id);
      if (!donor) return;
      deletingId = id;
      deleteMessage.textContent = donor.activo
        ? "¿Estás seguro de que deseas desactivar este donante?"
        : "¿Estás seguro de que deseas eliminar este donante?";
      deleteNote.style.display = donor.activo ? "" : "none";
      deleteModal.classList.remove("hidden");
    }

    // Blood type filter pills
    document.querySelectorAll(".pill").forEach((pill) => {
      pill.addEventListener("click", () => {
        const bt = pill.dataset.blood;
        if (activeBloodFilter === bt) {
          activeBloodFilter = null;
          pill.classList.remove("pill--active");
        } else {
          document
            .querySelectorAll(".pill")
            .forEach((p) => p.classList.remove("pill--active"));
          activeBloodFilter = bt;
          pill.classList.add("pill--active");
        }
        filterDonors();
      });
    });

    // Search
    searchInput.addEventListener("input", filterDonors);

    // Open create modal
    document
      .getElementById("open-create-modal")
      .addEventListener("click", openCreateModal);

    // Modal close
    function closeModals() {
      modal.classList.add("hidden");
      deleteModal.classList.add("hidden");
    }

    document
      .getElementById("modal-close")
      .addEventListener("click", closeModals);
    document
      .getElementById("modal-cancel")
      .addEventListener("click", closeModals);
    document
      .getElementById("delete-modal-close")
      .addEventListener("click", closeModals);
    document
      .getElementById("delete-cancel")
      .addEventListener("click", closeModals);

    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModals();
    });
    deleteModal.addEventListener("click", (e) => {
      if (e.target === deleteModal) closeModals();
    });

    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModals();
    });

    // Form submit (create/update)
    donorForm.addEventListener("submit", (e) => {
      e.preventDefault();
      formError.classList.add("hidden");

      const nombre = document.getElementById("donor-nombre").value.trim();
      const apellido = document.getElementById("donor-apellido").value.trim();
      const ci = document.getElementById("donor-ci").value.trim();
      const fecha_nacimiento = document.getElementById("donor-fecha-nac").value;
      const telefono = document.getElementById("donor-telefono").value.trim();
      const tipo_sangre = document.getElementById("donor-tipo-sangre").value;

      if (
        !nombre ||
        !apellido ||
        !ci ||
        !fecha_nacimiento ||
        !telefono ||
        !tipo_sangre
      ) {
        formError.textContent =
          "Todos los campos obligatorios deben ser completados.";
        formError.classList.remove("hidden");
        return;
      }

      const ciExists = donors.some((d) => d.ci === ci && d.id !== editingId);
      if (ciExists) {
        formError.textContent = "El número de cédula ya está registrado.";
        formError.classList.remove("hidden");
        return;
      }

      const email = document.getElementById("donor-email").value.trim();
      const direccion = document.getElementById("donor-direccion").value.trim();

      if (editingId) {
        const idx = donors.findIndex((d) => d.id === editingId);
        if (idx !== -1) {
          donors[idx] = {
            ...donors[idx],
            nombre,
            apellido,
            ci,
            fecha_nacimiento,
            telefono,
            tipo_sangre,
            email,
            direccion,
          };
        }
      } else {
        donors.push({
          id: nextId++,
          nombre,
          apellido,
          email,
          ci,
          tipo_sangre,
          ultima_donacion: "Nunca",
          activo: true,
          telefono,
          fecha_nacimiento,
          direccion,
        });
      }

      filterDonors();
      closeModals();
    });

    // Delete confirm
    document.getElementById("delete-confirm").addEventListener("click", () => {
      const donor = donors.find((d) => d.id === deletingId);
      if (!donor) return;

      if (donor.activo) {
        donor.activo = false;
      } else {
        const idx = donors.findIndex((d) => d.id === deletingId);
        if (idx !== -1) donors.splice(idx, 1);
      }

      filterDonors();
      closeModals();
    });

    // Initial render
    renderTable(donors);
  })();
</script>

