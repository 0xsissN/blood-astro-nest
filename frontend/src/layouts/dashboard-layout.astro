---
import '../styles/global.css';
import SideNav from '../components/dashboard/side-nav.astro';
import TopBar from '../components/dashboard/top-bar.astro';

interface Props {
  title?: string;
  currentSection?: string;
}

const {
  title = 'Hemocentro - Dashboard',
  currentSection = 'donantes',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="dashboard-body">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-brand">
          <svg
            width="32"
            height="32"
            viewBox="0 0 40 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle cx="20" cy="20" r="20" fill="#bc002d"></circle>
            <path
              d="M20 8C15.58 8 12 11.58 12 16C12 22 20 32 20 32C20 32 28 22 28 16C28 11.58 24.42 8 20 8Z"
              fill="white"></path>
          </svg>
          <div class="brand-text">
            <span class="brand-name">Hemocentro</span>
            <span class="brand-slogan">GESTIÓN DE VIDA</span>
          </div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a
          href="/center/dashboard"
          class:list={[
            "nav-item",
            { "nav-item--active": "dashboard" === activeSection },
          ]}
        >
          <span class="nav-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="3" width="7" height="7"></rect><rect
                x="14"
                y="3"
                width="7"
                height="7"></rect><rect x="14" y="14" width="7" height="7"
              ></rect><rect x="3" y="14" width="7" height="7"></rect></svg
            >
          </span>
          <span class="nav-text">Dashboard</span>
        </a>
        <a
          href="/center/donors"
          class:list={[
            "nav-item",
            { "nav-item--active": "donantes" === activeSection },
          ]}
        >
          <span class="nav-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><path
                d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path
                d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
            >
          </span>
          <span class="nav-text">Donantes</span>
        </a>
        <a
          href="/center/donation"
          class:list={[
            "nav-item",
            { "nav-item--active": "donaciones" === activeSection },
          ]}
        >
          <span class="nav-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 2C12 2 7 7 7 12a5 5 0 0 0 10 0c0-5-5-10-5-10z"
              ></path></svg
            >
          </span>
          <span class="nav-text">Donaciones</span>
        </a>
        <a
          href="/center/campaigns"
          class:list={[
            "nav-item",
            { "nav-item--active": "campañas" === activeSection },
          ]}
        >
          <span class="nav-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
              ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
            >
          </span>
          <span class="nav-text">Campañas</span>
        </a>
        <a
          href="/center/inventory"
          class:list={[
            "nav-item",
            { "nav-item--active": "inventario" === activeSection },
          ]}
        >
          <span class="nav-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
              ></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line
                x1="12"
                y1="22.08"
                x2="12"
                y2="12"></line></svg
            >
          </span>
          <span class="nav-text">Inventario</span>
        </a>
        <a
          href="/center/reports"
          class:list={[
            "nav-item",
            { "nav-item--active": "reportes" === activeSection },
          ]}
        >
          <span class="nav-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="18" y1="20" x2="18" y2="10"></line><line
                x1="12"
                y1="20"
                x2="12"
                y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg
            >
          </span>
          <span class="nav-text">Reportes</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <button class="new-donation-btn">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nueva Donación
        </button>
      </div>
    </aside>

    <div class="main-area">
      <header class="topbar">
        <div class="topbar-left">
          <div class="search-box">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input
              type="text"
              placeholder="Buscar donantes, unidades o campañas..."
            />
          </div>
        </div>
        <div class="topbar-right">
          <button class="icon-btn">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
          </button>
          <button class="icon-btn">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </button>
          <div class="user-profile" id="user-profile">
            <div class="avatar">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <div class="user-info">
              <span class="user-name" id="user-name">Admin Hemocentro</span>
              <span class="user-role" id="user-role">Director Nacional</span>
            </div>
          </div>
          <button class="icon-btn" id="logout-btn" title="Cerrar sesión">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
          </button>
        </div>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  body {
    display: flex;
    min-height: 100vh;
    background-color: #fff8f7;
    font-family: 'Inter', sans-serif;
    color: #281717;
    margin: 0;
  }

  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #e4bdbc;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #906f6f;
  }

  .dashboard-main {
    margin-left: 260px;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .dashboard-content {
    flex: 1;
    padding: 1.5rem;
  }

  @media (max-width: 768px) {
    .dashboard-main {
      margin-left: 0;
    }
  }
</style>
