---
interface Props {
  currentSection?: string;
}

const { currentSection = "donantes" } = Astro.props;

const navItems = [
  { id: "dashboard", label: "Dashboard", icon: "dashboard" },
  { id: "donantes", label: "Donantes", icon: "group" },
  { id: "donaciones", label: "Donaciones", icon: "bloodtype" },
  { id: "campanas", label: "Campañas", icon: "campaign" },
  { id: "inventario", label: "Inventario", icon: "analytics" },
  { id: "reportes", label: "Reportes", icon: "analytics" },
];
---

<aside class="sidebar">
  <div class="sidebar__brand">
    <div class="sidebar__logo">
      <svg
        width="24"
        height="24"
        viewBox="0 0 40 40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle cx="20" cy="20" r="20" fill="#bc002d"></circle>
        <path
          d="M20 8C15.58 8 12 11.58 12 16C12 22 20 32 20 32C20 32 28 22 28 16C28 11.58 24.42 8 20 8Z"
          fill="white"></path>
      </svg>
    </div>
    <div>
      <h1 class="sidebar__title">BancoVida</h1>
      <p class="sidebar__subtitle">Gestión de Vida</p>
    </div>
  </div>
  <nav class="sidebar__nav">
    {
      navItems.map((item) => (
        <a
          href={
            item.id === "dashboard" ? "/dashboard" : `/dashboard/${item.id}`
          }
          class:list={[
            "sidebar__link",
            { "sidebar__link--active": currentSection === item.id },
          ]}
        >
          <svg
            class="sidebar__link-icon"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            {item.id === "dashboard" &&
              '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>'}
            {item.id === "donantes" &&
              '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'}
            {item.id === "donaciones" &&
              '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>'}
            {item.id === "campanas" &&
              '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>'}
            {item.id === "inventario" &&
              '<path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-3-3L7 14"/>'}
            {item.id === "reportes" &&
              '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>'}
          </svg>
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="sidebar__footer">
    <a href="/dashboard/donaciones/nueva" class="sidebar__fab">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="12" y1="5" x2="12" y2="19"></line><line
          x1="5"
          y1="12"
          x2="19"
          y2="12"></line></svg
      >
      Nueva Donación
    </a>
    <a href="/" class="sidebar__link sidebar__link--back">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg
      >
      Volver al sitio
    </a>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    width: 260px;
    height: 100vh;
    background-color: #ffffff;
    border-right: 1px solid #e4bdbc;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem;
    z-index: 50;
    overflow-y: auto;
  }

  .sidebar__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .sidebar__logo {
    width: 2.5rem;
    height: 2.5rem;
    background-color: #bc002d;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar__logo svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .sidebar__title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #8f0020;
    line-height: 1.2;
  }

  .sidebar__subtitle {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #5c403f;
    opacity: 0.7;
  }

  .sidebar__nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #5c403f;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .sidebar__link:hover {
    background-color: #ffe1e0;
    color: #8f0020;
  }

  .sidebar__link--active {
    color: #8f0020;
    background-color: #ffdad9;
    border-right: 3px solid #bc002d;
    font-weight: 700;
  }

  .sidebar__link-icon {
    flex-shrink: 0;
  }

  .sidebar__link-icon :global(path),
  .sidebar__link-icon :global(rect),
  .sidebar__link-icon :global(circle),
  .sidebar__link-icon :global(line),
  .sidebar__link-icon :global(polyline) {
    stroke: currentColor;
  }

  .sidebar__footer {
    padding-top: 1rem;
    border-top: 1px solid #e4bdbc;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar__fab {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background-color: #bc002d;
    color: #ffffff;
    border-radius: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .sidebar__fab:hover {
    background-color: #8f0020;
    color: #ffffff;
  }

  .sidebar__link--back {
    font-size: 0.75rem;
    opacity: 0.8;
  }
</style>
