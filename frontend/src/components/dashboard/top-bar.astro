---

<header class="topbar">
  <div class="topbar__search">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c403f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="global-search" class="topbar__search-input" placeholder="Buscar donante por nombre o CI..." />
  </div>
  <div class="topbar__right">
    <button class="topbar__icon-btn" aria-label="Notificaciones">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5c403f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </button>
    <button class="topbar__icon-btn" aria-label="Ayuda">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5c403f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    </button>
    <div class="topbar__avatar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
  </div>
</header>

<style>
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 1.5rem;
    background-color: #ffffff;
    border-bottom: 1px solid #e4bdbc;
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .topbar__search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: #fff0ef;
    border: 1px solid #e4bdbc;
    border-radius: 9999px;
    max-width: 400px;
    width: 100%;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .topbar__search:focus-within {
    border-color: #bc002d;
    box-shadow: 0 0 0 3px rgba(188, 0, 45, 0.1);
  }

  .topbar__search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #281717;
    outline: none;
  }

  .topbar__search-input::placeholder {
    color: #906f6f;
  }

  .topbar__right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .topbar__icon-btn {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: none;
    border-radius: 50%;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .topbar__icon-btn:hover {
    background-color: #ffe1e0;
  }

  .topbar__avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: #bc002d;
    border: 2px solid #e4bdbc;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
</style>
