---
import banco from "../../images/banco_sangre_2.webp";
---

<header class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container">
    <div class="hero__grid">
      <div class="hero__content">
        <h1 class="hero__title">Tu sangre salva vidas</h1>
        <p class="hero__subtitle">
          Miles de personas dependen de tu generosidad. Encuentra tu centro de
          donación más cercano y agenda tu cita hoy mismo para marcar la
          diferencia.
        </p>
      </div>

      <img src={banco.src} alt="Banco de sangre" class="hero__image-img" />
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 0 6rem;
    background-color: #fff;
  }

  .hero__bg {
    position: absolute;
    top: -50%;
    right: -10%;

    width: 600px;
    height: 600px;
    border-radius: 50%;

    background: radial-gradient(
      circle,
      rgba(188, 0, 45, 0.04) 0%,
      rgba(188, 0, 45, 0.02) 50%,
      transparent 70%
    );

    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;

    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hero__content {
      grid-column: 1;
      order: 1;
    }

    .hero__image-img {
      grid-column: 2;
      order: 2;
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero__title {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;

    color: #8f0020;
  }

  .hero__subtitle {
    max-width: 580px;

    font-size: 1rem;
    line-height: 1.7;

    color: #5c403f;
  }

  .hero__image-img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 0.75rem;
  }

  @media (min-width: 640px) {
    .hero__title {
      font-size: 2.75rem;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding: 5.5rem 0 3rem;
    }

    .hero__bg {
      width: 300px;
      height: 300px;
    }
  }
</style>
