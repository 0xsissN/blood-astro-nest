---
interface Stat {
  value: string;
  label: string;
}

const stats: Stat[] = [
  { value: '12,500+', label: 'Donaciones realizadas' },
  { value: '5,800+', label: 'Donantes registrados' },
  { value: '48', label: 'Campañas realizadas' },
  { value: '98%', label: 'Satisfacción' },
];
---

<section class="stats-bar">
  <div class="container">
    <div class="stats-bar__grid">
      {stats.map((stat) => (
        <div class="stats-bar__item">
          <span class="stats-bar__value">{stat.value}</span>
          <span class="stats-bar__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-bar {
    background-color: #bc002d;
    padding: 3rem 0;
  }

  .stats-bar__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats-bar__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stats-bar__value {
    font-size: 2.25rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .stats-bar__label {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 400;
  }

  @media (max-width: 767px) {
    .stats-bar {
      padding: 2rem 0;
    }

    .stats-bar__value {
      font-size: 1.75rem;
    }
  }
</style>
