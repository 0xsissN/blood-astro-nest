---
import { apiGet } from "../../scripts/api";
import type { CampaignResponseDto } from "../../types/campaign";

let campaigns: CampaignResponseDto[] = [];
try {
  campaigns = await apiGet<CampaignResponseDto[]>("/campaigns");
} catch {
  campaigns = [
    { "id": 1, "nombre": "Campaña Universidad Central", "lugar": "Plaza de las Américas, Sede Norte", "fechaInicio": "2025-10-25", "fechaFin": "2025-10-27", "activa": true },
    { "id": 2, "nombre": "Jornada Empresarial Tech Hub", "lugar": "Auditorio Principal Edificio Quantum", "fechaInicio": "2025-10-28", "fechaFin": "2025-10-30", "activa": true },
    { "id": 3, "nombre": "Feria de Salud Parque Metropolitano", "lugar": "Zona de Eventos B, Puerta 4", "fechaInicio": "2025-11-01", "fechaFin": "2025-11-05", "activa": true },
  ] as CampaignResponseDto[];
}
---

<section class="section" id="campanas">
  <div class="container">
    <div class="campaigns__header">
      <div>
        <h2 class="section-title">Próximas Campañas</h2>
        <p class="section-subtitle">Llevamos el Hemocentro a tu comunidad.</p>
      </div>
    </div>
    <div class="campaigns__scroll hide-scrollbar">
      {
        campaigns.map((camp) => (
          <article class="campaign-card">
            <div class="campaign-card__body">
              <h3 class="campaign-card__title">{camp.nombre}</h3>
              <div class="campaign-card__details">
                <div class="campaign-card__detail">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#bc002d"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </>
                  </svg>
                  {camp.fechaInicio + " - " + camp.fechaFin}
                </div>
                <div class="campaign-card__detail">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#bc002d"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                      <circle cx="12" cy="10" r="3" />
                    </>
                  </svg>
                  {camp.lugar}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .campaigns__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .campaigns__view-all {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;

    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;

    color: #8f0020;
    text-decoration: none;
  }

  .campaigns__view-all:hover {
    text-decoration: underline;
  }

  .campaigns__scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }

  .campaign-card {
    flex-shrink: 0;
    width: 320px;

    background-color: #ffffff;
    border: 1px solid #e4bdbc;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .campaign-card {
      width: 400px;
    }
  }

  .campaign-card__body {
    padding: 1.5rem;
  }

  .campaign-card__title {
    margin-bottom: 1rem;

    font-size: 1.125rem;
    font-weight: 600;
    color: #281717;
  }

  .campaign-card__details {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .campaign-card__detail {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    font-size: 0.875rem;
    color: #5c403f;
  }

  .campaign-card__detail svg {
    flex-shrink: 0;
  }

  .campaign-card__btn {
    display: block;
    width: 100%;
    padding: 0.625rem;

    border: 1.5px solid #bc002d;
    border-radius: 0.5rem;

    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;

    color: #8f0020;
    text-decoration: none;

    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .campaign-card__btn:hover {
    background-color: #bc002d;
    color: #ffffff;
  }
</style>
