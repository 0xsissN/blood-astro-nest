---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <span class="footer__brand-name">Hemocentro Nacional</span>
        <p class="footer__tagline">
          Comprometidos con el suministro ético y oportuno de sangre segura para todo el país.
        </p>
        <div class="footer__social">
          <a href="#" class="footer__social-link" aria-label="Sitio web">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </a>
          <a href="#" class="footer__social-link" aria-label="Compartir">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4 class="footer__heading">Nosotros</h4>
        <ul class="footer__links">
          <li><a href="#">Quiénes Somos</a></li>
          <li><a href="/contacto">Nuestras Sedes</a></li>
          <li><a href="#">Transparencia</a></li>
          <li><a href="#">Noticias</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4 class="footer__heading">Ayuda</h4>
        <ul class="footer__links">
          <li><a href="/preguntas-frecuentes">Preguntas Frecuentes</a></li>
          <li><a href="/requisitos">Requisitos de Donación</a></li>
          <li><a href="/requisitos">Proceso Post-Donación</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4 class="footer__heading">Contacto Directo</h4>
        <div class="footer__contact">
          <div class="footer__contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#bc002d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <div>
              <p class="footer__contact-label">Línea Gratuita</p>
              <p class="footer__contact-value">0800-DONAR-01</p>
            </div>
          </div>
          <div class="footer__contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#bc002d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <p class="footer__contact-label">Email</p>
              <p class="footer__contact-value">info@hemocentronacional.gov</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} Hemocentro Nacional. La donación de sangre salva vidas.</p>
      <div class="footer__bottom-links">
        <a href="#">Privacidad</a>
        <a href="#">Términos</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #fadbda;
    padding: 4rem 0 0;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid #e4bdbc;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .footer__brand-name {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #8f0020;
    display: block;
    margin-bottom: 0.75rem;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: #5c403f;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social-link {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    border-radius: 50%;
    color: #8f0020;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .footer__social-link:hover {
    background-color: #bc002d;
    color: #ffffff;
  }

  .footer__heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #281717;
    margin-bottom: 1rem;
  }

  .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__links a {
    font-size: 0.875rem;
    color: #5c403f;
    transition: color 0.2s ease;
  }

  .footer__links a:hover {
    color: #8f0020;
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .footer__contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer__contact-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #281717;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.125rem;
  }

  .footer__contact-value {
    font-size: 0.875rem;
    color: #5c403f;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 0;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer__bottom p {
    font-size: 0.8125rem;
    color: #5c403f;
  }

  .footer__bottom-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer__bottom-links a {
    font-size: 0.8125rem;
    color: #5c403f;
    text-decoration: underline;
  }

  .footer__bottom-links a:hover {
    color: #8f0020;
  }
</style>
