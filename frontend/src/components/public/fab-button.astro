---

<button class="fab" id="fab-btn" aria-label="Agendar cita">
  <svg class="fab__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
  </svg>
  <span class="fab__tooltip">Agendar Cita</span>
</button>

<script>
  const fab = document.getElementById('fab-btn');
  if (fab) {
    fab.addEventListener('click', () => {
      window.location.href = '/contacto';
    });
  }
</script>

<style>
  .fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 4rem;
    height: 4rem;
    background-color: #bc002d;
    color: #ffffff;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(188, 0, 45, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    z-index: 50;
  }

  .fab:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 24px rgba(188, 0, 45, 0.4);
  }

  .fab:active {
    transform: scale(0.95);
  }

  .fab__icon {
    transition: transform 0.2s ease;
  }

  .fab:hover .fab__icon {
    transform: scale(1.1);
  }

  .fab__tooltip {
    position: absolute;
    right: calc(100% + 0.75rem);
    background-color: #ffffff;
    color: #281717;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    border: 1px solid #e4bdbc;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .fab:hover .fab__tooltip {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .fab {
      bottom: 1rem;
      right: 1rem;
      width: 3.5rem;
      height: 3.5rem;
    }
  }
</style>
